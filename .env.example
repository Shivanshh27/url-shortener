# Backend Environment Variables Sample

# Port on which the express server runs
PORT=5000

# Base URL used to prefix the shortened links
BASE_URL=http://localhost:5000

# Frontend client URL (for CORS allowance)
FRONTEND_URL=http://localhost:5173

# Local Database Connection (Fallbacks if DATABASE_URL is not set)
DB_USER=postgres
DB_HOST=localhost
DB_NAME=url_shortener
DB_PASSWORD=your_local_db_password
DB_PORT=5432

# Production / Cloud Database connection string (e.g. Neon, Render PostgreSQL)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require
